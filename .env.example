# Flask
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Required in production (app will fail to start without these)
SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me-strong-password
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Application
APP_NAME=Dan Ochieng & Company Advocates
BASE_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///lawfirm.db
# DATABASE_URL=postgresql://user:password@localhost:5432/lawfirm

# Admin bootstrap (used only when creating the first admin user)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com

# Email (Resend)
RESEND_FROM_EMAIL=onboarding@resend.dev
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# Business hours (24h format, UTC or local per BUSINESS_HOURS_TZ)
BUSINESS_HOURS_TZ=Africa/Nairobi
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=17
BUSINESS_HOURS_DAYS=0,1,2,3,4

# Calendly (optional)
CALENDLY_URL=

# Server
PORT=5000
