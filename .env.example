# Application
APP_NAME=Dan Ochieng & Company Advocates
BASE_URL=http://localhost:5000
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# Database (SQLite for dev, SQLite Cloud or PostgreSQL for production)
DATABASE_URL=sqlite:///lawfirm.db
# DATABASE_URL=postgresql://user:password@localhost:5432/lawfirm

# SQLite Cloud (set USE_SQLITECLOUD=true for production cloud DB)
USE_SQLITECLOUD=false
SQLITECLOUD_API_KEY=your-orgkey-here
SQLITECLOUD_GATEWAY_URL=https://your-project-id.g1.gateway.sqlite.cloud
SQLITECLOUD_DATABASE=lawfirm.db
# Preferred: paste the full connection string from the SQLite Cloud dashboard
# SQLITECLOUD_CONNECTION_STRING=sqlitecloud://your-id.g1.sqlite.cloud:8860/lawfirm.db?apikey=YOUR_KEY
# Or split host + key instead of gateway URL:
# SQLITECLOUD_HOST=your-id.g1.sqlite.cloud
# SQLITECLOUD_APIKEY=your-api-key-here
# Weblite REST bearer mode: orgkey (default) or connection_string
# SQLITECLOUD_BEARER_MODE=orgkey

# Admin bootstrap (used only when creating the first admin user)
ADMIN_USERNAME=admin
ADMIN_EMAIL=stanlleylocke@gmail.com

# Email (Resend)
RESEND_FROM_EMAIL=noreply@yieyo.stanlley.me
ADMIN_NOTIFICATION_EMAIL=stanlleylocke@gmail.com

